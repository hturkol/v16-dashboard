<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Enhanced Date Selection Bits Template -->
    <t t-name="dashboard_period_customization.EnhancedDateSelectionBits" owl="1">
        <div class="o_ds_value_cell">
            <select t-att-value="props.date" class="o_domain_leaf_operator_select o_input text-truncate pe-1" t-on-change="onchange">
                <option value="today">Bugün</option>
                <option value="this_week">Bu Hafta</option>
                <option value="this_month">Bu Ay</option>
                <option value="this_quarter">Bu Çeyrek</option>
                <option value="this_year">Bu Yıl</option>
                <option value="last_day">Son Gün</option>
                <option value="last_week">Son Hafta</option>
                <option value="last_month">Son Ay</option>
                <option value="last_quarter">Son Çeyrek</option>
                <option value="last_year">Son Yıl</option>
                <option value="last_7_days">Son 7 Gün</option>
                <option value="last_30_days">Son 30 Gün</option>
                <option value="last_90_days">Son 90 Gün</option>
                <option value="last_180_days">Son 180 Gün</option>
                <option value="last_365_days">Son 365 Gün</option>
                <option value="last_3_years">Son 3 Yıl</option>
                <option value="custom_range">📅 Özel Tarih Aralığı</option>
                <option value="next_day">Sonraki Gün</option>
                <option value="next_week">Sonraki Hafta</option>
                <option value="next_month">Sonraki Ay</option>
                <option value="next_quarter">Sonraki Çeyrek</option>
                <option value="next_year">Sonraki Yıl</option>
            </select>
        </div>
    </t>

    <!-- Custom Date Range Modal Template -->
    <t t-name="dashboard_period_customization.CustomDateRangeModal" owl="1">
        <div class="modal fade custom-date-range-modal" t-att-id="modalId" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Özel Tarih Aralığı Seçin</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" t-on-click="_onCloseModal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label t-att-for="'startDate_' + modalId" class="form-label">Başlangıç Tarihi</label>
                            <input t-att-id="'startDate_' + modalId" type="date" class="form-control" t-model="state.customStartDate"/>
                        </div>
                        <div class="mb-3">
                            <label t-att-for="'endDate_' + modalId" class="form-label">Bitiş Tarihi</label>
                            <input t-att-id="'endDate_' + modalId" type="date" class="form-control" t-model="state.customEndDate"/>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" t-on-click="_onCloseModal">İptal</button>
                        <button type="button" class="btn btn-primary" t-on-click="_onApplyCustomRange">Uygula</button>
                    </div>
                </div>
            </div>
        </div>
    </t>

</templates>
